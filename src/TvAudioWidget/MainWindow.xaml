<Window x:Class="TvAudioWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TV Audio Widget"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown"
        d:DesignHeight="900"
        d:DesignWidth="1440">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <Style x:Key="HeaderButton" TargetType="Button">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="56" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PanelButton" TargetType="Button">
      <Setter Property="MinWidth" Value="112" />
      <Setter Property="Height" Value="56" />
      <Setter Property="Padding" Value="18,0" />
      <Setter Property="Margin" Value="8,0" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Background" Value="{DynamicResource AccentMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="DeviceCardButton" TargetType="Button">
      <Setter Property="Width" Value="360" />
      <Setter Property="Height" Value="190" />
      <Setter Property="Margin" Value="12" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="{DynamicResource CardBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AccentMutedBrush}" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Style.Triggers>
        <Trigger Property="IsKeyboardFocused" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
          <Setter Property="BorderThickness" Value="4" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border x:Name="RootPanel"
          CornerRadius="8"
          Padding="36"
          Background="{DynamicResource RootBrush}"
          BorderBrush="{DynamicResource AccentMutedBrush}"
          BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="电视音频控制"
                     FontSize="44"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextBrush}" />
          <TextBlock x:Name="CurrentDeviceText"
                     Margin="0,10,0,0"
                     FontSize="24"
                     Foreground="{DynamicResource MutedTextBrush}"
                     Text="正在读取默认输出设备..." />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
          <Button Style="{StaticResource HeaderButton}"
                  ToolTip="刷新设备"
                  Content="&#xE72C;"
                  Click="RefreshButton_Click" />
          <Button Style="{StaticResource HeaderButton}"
                  ToolTip="设置"
                  Content="&#xE713;"
                  Click="SettingsButton_Click" />
          <Button Style="{StaticResource HeaderButton}"
                  ToolTip="关闭"
                  Content="&#xE711;"
                  Click="CloseButton_Click" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1" Margin="0,28,0,26">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Style="{StaticResource PanelButton}"
                Content="-"
                Click="VolumeDownButton_Click" />

        <StackPanel Grid.Column="1" Margin="20,0">
          <TextBlock x:Name="VolumeText"
                     FontSize="26"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextBrush}"
                     Text="音量 0%" />
          <Slider x:Name="MasterVolumeSlider"
                  Margin="0,12,0,0"
                  Minimum="0"
                  Maximum="100"
                  TickFrequency="5"
                  IsSnapToTickEnabled="False"
                  ValueChanged="MasterVolumeSlider_ValueChanged" />
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal">
          <Button Style="{StaticResource PanelButton}"
                  Content="+"
                  Click="VolumeUpButton_Click" />
          <Button x:Name="MuteButton"
                  Style="{StaticResource PanelButton}"
                  Content="静音"
                  Click="MuteButton_Click" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ItemsControl x:Name="DeviceItems">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Style="{StaticResource DeviceCardButton}"
                        Tag="{Binding Id}"
                        Click="DeviceButton_Click">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding IconGlyph}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="44"
                               Foreground="{DynamicResource AccentBrush}" />

                    <TextBlock Grid.Row="1"
                               Margin="0,18,0,10"
                               Text="{Binding Name}"
                               FontSize="26"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource TextBrush}" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                      <Border Padding="10,4"
                              CornerRadius="8"
                              Background="{DynamicResource AccentMutedBrush}"
                              Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="默认输出"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                      </Border>
                      <Border Padding="10,4"
                              Margin="8,0,0,0"
                              CornerRadius="8"
                              Background="{DynamicResource ControlBrush}"
                              Visibility="{Binding IsDefaultCommunications, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="通信"
                                   FontSize="17"
                                   Foreground="{DynamicResource TextBrush}" />
                      </Border>
                    </StackPanel>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Border x:Name="SettingsPanel"
                Grid.Column="1"
                Width="360"
                Margin="28,0,0,0"
                Padding="24"
                CornerRadius="8"
                Visibility="Collapsed"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource AccentMutedBrush}"
                BorderThickness="1">
          <StackPanel>
            <TextBlock Text="设置"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" />

            <TextBlock Text="主题色"
                       Margin="0,28,0,10"
                       FontSize="20"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <ComboBox x:Name="ThemeSelector"
                      Height="48"
                      FontSize="20"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectionChanged="ThemeSelector_SelectionChanged" />

            <TextBlock Text="面板透明度"
                       Margin="0,28,0,10"
                       FontSize="20"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <Slider x:Name="PanelOpacitySlider"
                    Minimum="0.58"
                    Maximum="0.96"
                    TickFrequency="0.02"
                    ValueChanged="PanelOpacitySlider_ValueChanged" />

            <TextBlock x:Name="OpacityValueText"
                       Margin="0,8,0,0"
                       FontSize="18"
                       Foreground="{DynamicResource MutedTextBrush}" />

            <TextBlock Text="音量步进"
                       Margin="0,28,0,10"
                       FontSize="20"
                       Foreground="{DynamicResource MutedTextBrush}" />
            <Slider x:Name="VolumeStepSlider"
                    Minimum="1"
                    Maximum="20"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    ValueChanged="VolumeStepSlider_ValueChanged" />

            <TextBlock x:Name="VolumeStepValueText"
                       Margin="0,8,0,0"
                       FontSize="18"
                       Foreground="{DynamicResource MutedTextBrush}" />
          </StackPanel>
        </Border>
      </Grid>

      <TextBlock x:Name="StatusText"
                 Grid.Row="3"
                 Margin="0,22,0,0"
                 FontSize="18"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource MutedTextBrush}" />
    </Grid>
  </Border>
</Window>
